<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/CSS/authstyles.css" />
  <title>NyaayDrishti | Court Master Login</title>
</head>
<body>
  <div class="auth-container">
    <div class="header">
      <h1>NyaayDrishti</h1>
      <p>Registry Personnel Portal</p>
    </div>

    <div class="form-container">
      <!-- ERROR MESSAGE -->
      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <div class="error-message">
          <p><%= error[0] %></p>
        </div>
      <% } %>

      <p class="auth-notice">🔒 Authorised registry personnel only</p>

      <!-- POST to the session-based judicial login handler -->
      <form method="POST" action="/judicial-login">
        <!-- Hidden field tells the controller which view to re-render on failure -->
        <input type="hidden" name="fromView" value="cmaster" />

        <div class="form-group">
          <label for="email">Official Email</label>
          <input
            type="email"
            name="email"
            id="email"
            placeholder="courtmaster@court.com"
            required
            autocomplete="username"
          />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input
            type="password"
            name="password"
            id="password"
            required
            autocomplete="current-password"
          />
        </div>

        <button type="submit" class="submit-btn">
          Login as Court Master
        </button>

        <div class="demo-data">
          Demo credentials:<br />
          Email: <strong>courtmaster@court.com</strong><br />
          Password: <strong>court123</strong>
        </div>

        <div class="disclaimer">
          This system facilitates case management and does not assist in judicial decision-making.
        </div>
      </form>
    </div>
  </div>
</body>
</html>
